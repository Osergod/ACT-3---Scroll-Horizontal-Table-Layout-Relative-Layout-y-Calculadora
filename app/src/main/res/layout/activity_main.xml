<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="250dp"
        android:text="ACT 3 - Scroll-Horizontal-Table, Layout-Relative, Layout y Calculadora"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/Act11"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <Button
        android:id="@+id/Act11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#780000"
        android:text="Actividad 11"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintBottom_toTopOf="@id/Act12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/Act12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#780000"
        android:text="Actividad 12"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/Act11"
        app:layout_constraintBottom_toTopOf="@id/Act13"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/Act13"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#780000"
        android:text="Actividad 13"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/Act12"
        app:layout_constraintBottom_toTopOf="@id/Act14"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/Act14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#780000"
        android:text="Actividad 14"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/Act13"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>