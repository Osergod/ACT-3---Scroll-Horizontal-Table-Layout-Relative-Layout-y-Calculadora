<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/gris"
        android:layout_width="120dp"
        android:layout_height="80dp"
        android:background="#D9D9D9"
        android:layout_alignParentTop="true"
        android:layout_alignParentLeft="true"/>

    <View
        android:id="@+id/morado"
        android:layout_width="169dp"
        android:layout_height="80dp"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="-29dp"
        android:layout_marginTop="0dp"
        android:layout_toRightOf="@id/gris"
        android:background="#6A3D9A" />

    <View
        android:id="@+id/rojoTop"
        android:layout_width="150dp"
        android:layout_height="80dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:layout_marginTop="0dp"
        android:background="#FF0066" />

    <View
        android:id="@+id/verde"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#4DB6AC"
        android:layout_below="@id/morado"
        android:layout_above="@id/naranja"/>

    <View
        android:id="@+id/naranja"
        android:layout_width="160dp"
        android:layout_height="200dp"
        android:background="#FFA000"
        android:layout_alignParentBottom="true"
        android:layout_alignParentLeft="true"/>

    <View
        android:id="@+id/rojoBottom"
        android:layout_width="251dp"
        android:layout_height="200dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="0dp"
        android:layout_marginRight="0dp"
        android:layout_marginBottom="0dp"
        android:background="#FF0066" />

</RelativeLayout>